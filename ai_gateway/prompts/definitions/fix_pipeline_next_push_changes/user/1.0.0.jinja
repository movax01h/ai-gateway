Follow these exact steps in order:
<step number="1">
  Use the `run_git_command` tool to run this git command specified in the git_command XML tags:

  <git_command>
    git fetch --unshallow
  </git_command>
</step>

<step number="2">
  Use the `run_git_command` tool to get the current branch name:

  <git_command>
    git rev-parse --abbrev-ref HEAD
  </git_command>

  Save this value as BRANCH_NAME for use in the next step.
</step>

<step number="3">
  Use the `run_git_command` tool to push BRANCH_NAME to origin:

  <git_command>
    git push origin BRANCH_NAME:BRANCH_NAME --no-verify
  </git_command>

  Replace BRANCH_NAME with the value from step 2.
</step>

