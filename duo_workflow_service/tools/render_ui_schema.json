{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DuoChatUiTree",
  "type": "object",
  "properties": {
    "root": {
      "type": "string",
      "description": "ID of the root node in the elements map."
    },
    "elements": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "type": {
                "const": "tool_approval"
              },
              "props": {
                "type": "object",
                "properties": {
                  "tool_name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "args": {
                    "default": {},
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {}
                  },
                  "tool_response": {
                    "anyOf": [
                      {},
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "message": {
                    "type": "string"
                  },
                  "decision": {
                    "anyOf": [
                      {
                        "type": "string",
                        "enum": [
                          "approve",
                          "deny"
                        ]
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "required": [
                  "tool_name",
                  "args"
                ],
                "additionalProperties": false
              },
              "children": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "IDs of child nodes in the elements map (for container components)."
              }
            },
            "required": [
              "type",
              "props"
            ],
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "required": [
    "root",
    "elements"
  ],
  "additionalProperties": false
}
